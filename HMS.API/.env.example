# Copy this file to .env and fill in the values
# .env is gitignored — never commit real secrets

# ── Database ──────────────────────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Host=...;Database=...;Username=...;Password=...;SSL Mode=Require;Trust Server Certificate=true

# ── JWT ───────────────────────────────────────────────────────────────────────
JwtSettings__Secret=<min-32-char-random-string>
JwtSettings__ExpiryMinutes=15
JwtSettings__RefreshTokenExpiryDays=7
JwtSettings__Issuer=HMS.API
JwtSettings__Audience=HMS.Client

# ── Resend (email) ────────────────────────────────────────────────────────────
ResendSettings__ApiKey=re_...
ResendSettings__FromEmail=HMS Hotel <noreply@yourdomain.com>

# ── Data protection (generate with: openssl rand -base64 32) ─────────────────
DataProtection__EncryptionKey=<base64-32-bytes>

# ── CORS ──────────────────────────────────────────────────────────────────────
FrontendUrl=http://localhost:4200
